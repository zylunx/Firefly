# AI Summary Configuration
# AI 总结功能配置
#
# 在 GitHub Actions / Cloudflare Pages 等部署平台中，
# 请将这些变量设置为环境变量（不要使用 .env 文件）。
#
# 环境变量优先级：系统环境变量 > .env 文件

# [必填] OpenAI API Key（或兼容服务的 Key）
OPENAI_API_KEY=your-api-key-here

# [可选] AI API 地址（支持 OpenAI 兼容接口，如 DeepSeek、Ollama、智谱等）
# 默认值：https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# [可选] AI 模型名称
# 默认值：gpt-4o-mini
# AI_MODEL=gpt-4o-mini

# [可选] 截取正文的最大字符数
# 默认值：4000
# AI_MAX_CONTENT_LENGTH=4000

# [可选] 生成总结的最大 token 数
# 默认值：300
# AI_SUMMARY_MAX_TOKENS=300

# [可选] 并发请求数（避免 API 限流）
# 默认值：3
# AI_CONCURRENCY=3
