---
/**
 * 通用页面标题组件
 *
 * 支持两种变体：
 * - `stacked`（默认）：副标题（eyebrow）在上，主标题在下，左对齐
 * - `inline`：副标题和主标题在同一行
 */
interface Props {
	/** 主标题 */
	title: string;
	/** 副标题（小字，显示在主标题上方或旁边） */
	eyebrow?: string;
	/** 显示变体 */
	variant?: "stacked" | "inline";
	class?: string;
	style?: string;
}

const {
	title,
	eyebrow,
	variant = "stacked",
	class: className,
	style,
} = Astro.props;
---

<div class:list={["page-title", `page-title--${variant}`, className]} style={style}>
	{eyebrow && (
		<span class="page-title__eyebrow">{eyebrow}</span>
	)}
	<h1 class="page-title__title">{title}</h1>
</div>

<style>
	.page-title {
		display: flex;
		color: var(--primary);
	}

	.page-title--stacked {
		flex-direction: column;
		gap: 0.25rem;
	}

	.page-title--inline {
		flex-direction: row;
		align-items: baseline;
		gap: 0.75rem;
	}

	.page-title__eyebrow {
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: var(--primary);
		opacity: 0.7;
	}

	.page-title__title {
		font-size: 1.75rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--primary);
		margin: 0;
	}
</style>
